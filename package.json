{
  "name": "jest-snapshot-serializer-ansi",
  "type": "module",
  "version": "2.2.1",
  "description": "jest snapshot serializer for stripping ANSI escape codes",
  "exports": "./lib/index.js",
  "repository": "https://github.com/ikatyang-collab/jest-snapshot-serializer-ansi",
  "homepage": "https://github.com/ikatyang-collab/jest-snapshot-serializer-ansi#readme",
  "author": {
    "name": "Ika",
    "email": "ikatyang@gmail.com",
    "url": "https://github.com/ikatyang"
  },
  "license": "MIT",
  "scripts": {
    "prepack": "pnpm run build",
    "lint": "prettier --check .",
    "test": "vitest",
    "build": "tsc -p ./tsconfig.build.json",
    "release": "standard-version"
  },
  "dependencies": {
    "has-ansi": "^6.0.0",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "prettier": "3.8.4",
    "standard-version": "9.5.0",
    "typescript": "6.0.3",
    "vite": "6.4.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=16"
  },
  "files": [
    "/lib/**/*",
    "/CHANGELOG.md"
  ],
  "packageManager": "pnpm@11.7.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
